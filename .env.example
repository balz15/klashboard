# Supabase - required for the app to work
# Get these from your Supabase project: Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public site URL for share links and deep links (no trailing slash)
VITE_PUBLIC_APP_URL=https://www.klashboard.com
# Play Store or landing page for "Get the app" in shares (optional)
# VITE_ANDROID_INSTALL_URL=https://play.google.com/store/apps/details?id=com.groupchallenge.app

# Comma-separated emails that can approve user-submitted templates (optional; or set profiles.is_app_admin in Supabase)
# VITE_APP_ADMIN_EMAILS=you@example.com