{
	"appId": "com.groupchallenge.app",
	"appName": "KlashBoard",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"cleartext": true
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"backgroundColor": "#ffffff",
			"androidSplashResourceName": "splash",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "light",
			"backgroundColor": "#1f2937"
		}
	}
}
